# API keys — copy to .env and never commit .env

# ElevenLabs — voiceovers & sound effects
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Pexels — stock footage search
PEXELS_API_KEY=your_pexels_api_key_here

# Cursor — optional SDK auto-agent (hidden worker, no CMD spam)
# Runs the SDK in a hidden worker process so Vite stays stable on Windows
# User API Key from https://cursor.com/dashboard → API Keys
CURSOR_API_KEY=your_cursor_api_key_here
CURSOR_AUTO_AGENT=true

# Optional: install @cursor/sdk for programmatic agent runs
# npm install @cursor/sdk
